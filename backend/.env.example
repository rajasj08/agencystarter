NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://user:password@localhost:5432/agencystarter
JWT_SECRET=your-super-secret-jwt-key-change-in-production
REQUIRE_EMAIL_VERIFICATION=false
API_PREFIX=/api/v1
# Public base URL of this API (for SSO callback). No trailing slash. IdP redirects here.
# API_PUBLIC_BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000
APP_NAME=Agency Starter
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=10
MAINTENANCE_MODE=false
# MAX_USERS_PER_AGENCY=0
# MAX_AGENCIES=0
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# SSO (optional). When false, GET /api/v1/auth/sso/* returns 404.
# AUTH_SSO_ENABLED=false
# AUTH_SSO_AUTO_PROVISION=false
